-- -- case 4: (regData(p,id-keygen(id1),ecdhk-keygen(e1),mlk-keygen(m1),sign(id1,regPayload(p,id-keygen(id1),ecdhk-keygen(e1),mlk-keygen(m1))))):RegData
-- open PQ3 .
--   op id1 : -> ID-SecretK .
--   op e1 : -> ECDHK-SecretK .
--   op m1 : -> MLK-SecretK .
--   op p : -> Prin .
--   op s1 : -> Sys .
