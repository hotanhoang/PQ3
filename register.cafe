open PQ3 .
  ops p q : -> Prin .
  ops id id' : -> ID-SecretK .
  ops ec ec' : -> ECDHK-SecretK .
  ops ml ml' : -> MLK-SecretK .

  op s1 : -> Sys .
  eq s1 = register(init, p, id, ec, ml) .

  -- registration ephemeral keys of p on IDS server
  red c-register(init, p, id, ec, ml) .

  -- 
  red active(s1, p, q, sid0(s1, p, q)) .
  -- IDS server should contain p
  red existUser(p, idsServer(s1)) .
  red getPrin(findRegData(p, idsServer(s1))) .
  red getIdPK(findRegData(p, idsServer(s1))) .
  red getEcdhkPK(findRegData(p, idsServer(s1))) .
  red getMlkPK(findRegData(p, idsServer(s1))) .
  red validRegData(findRegData(p, idsServer(s1))) .

  -- usedSecret tests
  red ec  \in usedSecret(s1) .
  red ml  \in usedSecret(s1) .

  -- network and time 
  red nw(s1) .
  red usedSecret(s1) .
  red idsServer(s1) .
  red time(s1) .

  red idsk(s1, p) .
  red lecdhsk(s1, p) .
  red lmlksk(s1, p) .

  red c-register(s1, q, id', ec, ml) .

  -- red c-register(s1, q, id', ec', ml') .
close