    ceq leakscr(intruComInitChainK(S, ES0, MS0)) = init-ck(ES0, MS0) leakscr(S) if c-intruComInitChainK(S, ES0, MS0) .
    ceq knl(intruComInitChainK(S, ES0, MS0)) = init-ck(ES0, MS0) || knl(S) if c-intruComInitChainK(S, ES0, MS0) .
    ceq intruComInitChainK(S, ES0, MS0) = S if not c-intruComInitChainK(S, ES0, MS0) .

    -- 20 compromise ratchet chain key
    op intruComChainK : Sys RootK ECDHK-ShareS MLK-ShareS -> Sys {constr}
    op c-intruComChainK : Sys RootK ECDHK-ShareS MLK-ShareS -> Bool
    eq c-intruComChainK(S, RK0, ES0, MS0) =
        (RK0 \in leakscr(S) and
         ES0 \in leakscr(S) and
         MS0 \in leakscr(S) and
         not (RK0 = noRootK) and
         not (RK0 = zero-rk)) .

    eq usedSK(intruComChainK(S, RK0, ES0, MS0)) = usedSK(S) .
    eq usedSID(intruComChainK(S, RK0, ES0, MS0)) = usedSID(S) .
    eq usedRM(intruComChainK(S, RK0, ES0, MS0)) = usedRM(S) .
    eq nw(intruComChainK(S, RK0, ES0, MS0)) = nw(S) .
    eq idsS(intruComChainK(S, RK0, ES0, MS0)) = idsS(S) .
    eq time(intruComChainK(S, RK0, ES0, MS0)) = time(S) .
    eq rk(intruComChainK(S, RK0, ES0, MS0), A, B, SID) = rk(S, A, B, SID) .
    eq ck(intruComChainK(S, RK0, ES0, MS0), A, B, SID) = ck(S, A, B, SID) .
    eq ns(intruComChainK(S, RK0, ES0, MS0), A, B, SID) = ns(S, A, B, SID) .
    eq nr(intruComChainK(S, RK0, ES0, MS0), A, B, SID) = nr(S, A, B, SID) .
    eq peerPKS(intruComChainK(S, RK0, ES0, MS0)) = peerPKS(S) .
    eq selfSKS(intruComChainK(S, RK0, ES0, MS0)) = selfSKS(S) .
    ceq leakscr(intruComChainK(S, RK0, ES0, MS0)) = kdf-ck(RK0, ES0, MS0) leakscr(S) if c-intruComChainK(S, RK0, ES0, MS0) .
    ceq knl(intruComChainK(S, RK0, ES0, MS0)) = ar-ck(RK0, ES0, MS0) || knl(S) if c-intruComChainK(S, RK0, ES0, MS0) .
    ceq intruComChainK(S, RK0, ES0, MS0) = S if not c-intruComChainK(S, RK0, ES0, MS0) .

    -- 21. intruder decrypts a symmetric message if it knows the exact message key used to encrypt it
    op intruDecMsg1 : Sys Prin Prin Prin SymBody Nat MsgK RawMsg -> Sys {constr}
    op c-intruDecMsg1 : Sys Prin Prin Prin SymBody Nat MsgK RawMsg -> Bool
    eq c-intruDecMsg1(S, A2, A, B, SB, N, MK, RM) =
        (
            MK \in knl(S) and
            senc(MK, RM) \in knl(S) and
            RM \in usedRM(S)
        ) .
    eq usedSK(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = usedSK(S) .
    eq usedSID(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = usedSID(S) .
    eq usedRM(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = usedRM(S) .
    eq nw(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = nw(S) .
    eq idsS(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = idsS(S) .
    eq time(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = time(S) .
    eq rk(intruDecMsg1(S, A2, A, B, SB, N, MK, RM), P, Q, SID) = rk(S, P, Q, SID) .
    eq ck(intruDecMsg1(S, A2, A, B, SB, N, MK, RM), P, Q, SID) = ck(S, P, Q, SID) .
    eq ns(intruDecMsg1(S, A2, A, B, SB, N, MK, RM), P, Q, SID) = ns(S, P, Q, SID) .
    eq nr(intruDecMsg1(S, A2, A, B, SB, N, MK, RM), P, Q, SID) = nr(S, P, Q, SID) .
    eq peerPKS(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = peerPKS(S) .
    eq selfSKS(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = selfSKS(S) .
    ceq leakscr(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) = leakscr(S) if c-intruDecMsg1(S, A2, A, B, SB, N, MK, RM) .
    ceq knl(intruDecMsg1(S, A2, A, B, SB, N, MK, RM)) =  RM || knl(S) if c-intruDecMsg1(S, A2, A, B, SB, N, MK, RM) .
    ceq intruDecMsg1(S, A2, A, B, SB, N, MK, RM) = S if not c-intruDecMsg1(S, A2, A, B, SB, N, MK, RM) .



    



}