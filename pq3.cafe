    eq nr(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H), P, Q, SID2) = nr(S, P, Q, SID2) .
    eq peerPKS(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = peerPKS(S) .
    eq selfSKS(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = selfSKS(S) .
    eq leakscr(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = leakscr(S) .
    eq knl(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = knl(S) .
    ceq fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H) = S if not c-fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H) .

