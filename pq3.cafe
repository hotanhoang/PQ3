    -- 16. fake message
    op fkInitMsg : Sys Prin Prin SessId ECDHK-Cipher MLK-Cipher ECDHK-PublicK MLK-PublicK RawMsg KeyHash -> Sys {constr}
    op c-fkInitMsg : Sys Prin Prin SessId ECDHK-Cipher MLK-Cipher ECDHK-PublicK MLK-PublicK RawMsg KeyHash -> Bool
    eq c-fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H) = (C1 \in knl(S) and C2 \in knl(S) and EPK \in knl(S) and MPK  \in knl(S) and H \in knl(S)) .
    eq usedSK(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = usedSK(S) .
    eq usedSID(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = usedSID(S) .
    eq usedRM(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = usedRM(S) .
    ceq nw(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) =
        (msg(intru, A, B,
                mkInitBody(intru, B, SID, C1, C2, EPK, MPK, ns(S, A, B, SID), ienc(mk-sym(ck(S, A, B, SID)), RM), H),
                time(S)),
            nw(S))
    if c-fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H) .
    eq idsS(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = idsS(S) .
    eq time(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H)) = s(time(S)) .
    eq rk(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H), P, Q, SID2) = rk(S, P, Q, SID2) .
    eq ck(fkInitMsg(S, A, B, SID, C1, C2, EPK, MPK, RM, H), P, Q, SID2) = ck(S, P, Q, SID2) .
