    ceq time(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N)) = s(time(S)) if c-intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N) .
    eq rk(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = rk(S, P, Q, SID) .
    eq ck(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = ck(S, P, Q, SID) .
    eq ns(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = ns(S, P, Q, SID) .
    eq nr(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = nr(S, P, Q, SID) .
    eq peerPKS(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N)) = peerPKS(S) .
    eq selfSKS(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N)) = selfSKS(S) .
    ceq leakscr(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N)) = (ECDHK-PriK(B) & ESK) leakscr(S) if c-intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N) .
    ceq knl(intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N)) = (ECDHK-PriK(B) & ESK) || knl(S) if c-intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N) .
    ceq intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N) = S if not c-intruComECDHKEMSS(S, A, B, SID, ESK, MSK, RM, N) .

    -- 10. compromise of KEM secret key 
    op intruComInitKEM : Sys Prin Prin SessId ECDHK-SecretK MLK-SecretK RawMsg Nat -> Sys {constr}
    op c-intruComInitKEM : Sys Prin Prin SessId ECDHK-SecretK MLK-SecretK RawMsg Nat -> Bool
    eq c-intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N) = 
            (
                ESK \in usedSK(S) and MSK \in usedSK(S) and
                msg(A, A, B, 
                mkInitBody(A, B, SID,
                    ct-ecdh(B, ESK),
                    ct-mlk(B, MSK),
                    ecdhk-keygen(ESK),
                    mlk-keygen(MSK),
                    ns(S, A, B, SID), 
                    ienc(mk-sym(ck(S, A, B, SID)), RM),
                    hash(ECDHK-PubK(B), MLK-PubK(B))), 
                N) \in nw(S)
            ) .
    eq usedSK(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = usedSK(S) .
    eq usedSID(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = usedSID(S) .
    eq usedRM(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = usedRM(S) .
    eq nw(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = nw(S) .
    eq idsS(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = idsS(S) .
    eq time(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = time(S) .
    eq rk(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = rk(S, P, Q, SID) .
    eq ck(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = ck(S, P, Q, SID) .
    eq ns(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = ns(S, P, Q, SID) .
    eq nr(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N), P, Q, SID) = nr(S, P, Q, SID) .
    eq peerPKS(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = peerPKS(S) .
    eq selfSKS(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = selfSKS(S) .
    ceq leakscr(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = ESK MSK leakscr(S) if c-intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N) .
    ceq knl(intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N)) = ESK || MSK || knl(S) if c-intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N) .
    ceq intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N) = S if not c-intruComInitKEM(S, A, B, SID, ESK, MSK, RM, N) .

    -- 11. compromise of long term private key of server
    op intruComLongTermEcdhSK : Sys Prin -> Sys {constr}
    op c-intruComLongTermEcdhSK : Sys Prin -> Bool
    eq c-intruComLongTermEcdhSK(S, A) = not(ECDHK-PriK(A) \in leakscr(S)) .
    eq usedSK(intruComLongTermEcdhSK(S, A)) = usedSK(S) .
