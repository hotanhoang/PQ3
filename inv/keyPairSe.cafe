  op a2 : -> Prin .
  op b : -> Prin .
  op esk : -> ECDHK-SecretK .
  op ib : -> InitBody .
  op msk : -> MLK-SecretK .
  op n : -> Nat .
  op r1 : -> MLK-SecretK .
  op r2 : -> MLK-Cipher .
  op s : -> Sys .
  op sid : -> SessId .
