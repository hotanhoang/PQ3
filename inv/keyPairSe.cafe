open INV .
  op a : -> Prin .
  op a2 : -> Prin .
  op b : -> Prin .
  op esk : -> ECDHK-SecretK .
  op ib : -> InitBody .
  op msk : -> MLK-SecretK .
  op n : -> Nat .
  op r1 : -> MLK-SecretK .
  op r2 : -> MLK-PublicK .
  op s : -> Sys .
  op sid : -> SessId .
  eq (r1 \in knl(s)) = true .
  eq (r2 \in knl(s)) = true .
  eq msk = r1 .
  eq (a = b) = false .
  eq (a = intru) = false .
  eq (b = intru) = false .
  eq mlk-getSecret(initMlkPkEph(ib)) = r1 .
  eq initSid(ib) = sid .
  eq validInitBody(a,sid,ib) = true .
  eq existUser(b,idsServer(s)) = true .
  eq (r1 \in leakscr(s)) = false .
  eq validRegData(findRegData(b,idsServer(s))) = true .
  eq (msg(a2,a,b,ib,n) \in nw(s)) = true .
  eq mlk-getSecret(r2) = MLK-PriK(b) .
  eq (MLK-PriK(b) \in leakscr(s)) = false .
  eq (sk(a) \in leakscr(s)) = false .
  eq ((MLK-PriK(b) & r1) \in knl(s)) = false .
  eq ((MLK-PriK(b) & r1) \in leakscr(s)) = false .
  eq initMlkCt(ib) = mlk-encapsC(mlk-keygen(MLK-PriK(b)),r1) .
  red inv2(s,r1) implies (keyPairSe(s,a2,a,b,sid,esk,msk,ib,n) implies keyPairSe(intruCalcMLKKEMInfo(s,r1,r2),a2,a,b,sid,esk,msk,ib,n)) .
close

