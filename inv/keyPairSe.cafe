  eq mlk-getSecret(initMlkPkEph(ib)) = msk .
  eq initSid(ib) = sid .
  eq validInitBody(a,sid,ib) = true .
  eq existUser(b,idsServer(s)) = true .
  eq (msk \in leakscr(s)) = false .
  eq validRegData(findRegData(b,idsServer(s))) = true .
