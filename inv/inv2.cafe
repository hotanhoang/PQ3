  eq sid = r3 .
  eq ckAt(kdf-ck(zero-rk,(ECDHK-PriK(r2) & esk),(MLK-PriK(r2) & msk)),ns(s,r1,r2,r3)) = ck(s,r1,r2,r3) .
  red inv2(s,a2,a,b,sid,esk,msk,ck,rm,sb,n) implies inv2(send-sym(s,r1,r2,r3,r4),a2,a,b,sid,esk,msk,ck,rm,sb,n) .
close

