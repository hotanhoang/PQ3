  op a : -> Prin .
  op a2 : -> Prin .
  op b : -> Prin .
  op ck : -> ChainK .
  op esk : -> ECDHK-SecretK .
  op msk : -> MLK-SecretK .
  op n : -> Nat .
  op r1 : -> Prin .
  op r2 : -> Prin .
  op r3 : -> SessId .
  op r4 : -> RawMsg .
  op rm : -> RawMsg .
  op s : -> Sys .
  op sb : -> SymBody .
  op sid : -> SessId .
  eq (r1 = r2) = false .
  eq (ck(s,r1,r2,r3) = noChainK) = false .
  eq (rk(s,r1,r2,r3) = noRootK) = false .
  eq (r3 \in usedSID(s)) = true .
  eq (r4 \in usedRM(s)) = false .
  eq a = r1 .
  eq a2 = r1 .
  eq b = r2 .
  eq (rm = noRawMsg) = false .
  eq r4 = rm .
  eq (rm \in usedRM(s)) = true .
  red inv2(s,a2,a,b,sid,esk,msk,ck,rm,sb,n) implies inv2(send-sym(s,r1,r2,r3,r4),a2,a,b,sid,esk,msk,ck,rm,sb,n) .
close

