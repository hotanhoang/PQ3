  red inv2(s,r1) implies (keyPairSeAsym(s,a2,a,b,sid,mpk,msk,ab,n) implies keyPairSeAsym(intruCalcMLKKEMInfo(s,r1,r2),a2,a,b,sid,mpk,msk,ab,n)) .
