  eq (r1 \in leakscr(s)) = false .
  eq (msg(a2,a,b,ab,n) \in nw(s)) = true .
  eq asymMlkCt(ab) = mlk-encapsC(mpk,r1) .
  eq (mlk-getSecret(mpk) \in leakscr(s)) = true .
