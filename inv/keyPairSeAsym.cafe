  op a2 : -> Prin .
  op ab : -> AsymBody .
  op b : -> Prin .
  op mpk : -> MLK-PublicK .
  op msk : -> MLK-SecretK .
  op n : -> Nat .
  op r1 : -> MLK-SecretK .
  op r2 : -> MLK-Cipher .
  op s : -> Sys .
  op sid : -> SessId .
  eq (r1 \in knl(s)) = true .
  eq (r2 \in knl(s)) = true .
  eq (a = b) = false .
  eq (a = intru) = false .
  eq (b = intru) = false .
  eq mlk-getSecret(asymMlkPkEph(ab)) = msk .
  eq asymSid(ab) = sid .
  eq validAsymBody(a,b,ab) = true .
  eq (msk \in leakscr(s)) = true .
  red keyPairSeAsym(s,a2,a,b,sid,mpk,msk,ab,n) implies keyPairSeAsym(intruMLKDecaps(s,r1,r2),a2,a,b,sid,mpk,msk,ab,n) .
close

