open INV .
  op a : -> Prin .
  op a2 : -> Prin .
  op ab : -> AsymBody .
  op b : -> Prin .
  op mpk : -> MLK-PublicK .
  op msk : -> MLK-SecretK .
  op n : -> Nat .
  op r1 : -> MLK-SecretK .
  op r2 : -> MLK-Cipher .
  op s : -> Sys .
  op sid : -> SessId .
  eq (r1 \in knl(s)) = true .
  eq (r2 \in knl(s)) = true .
  eq (a = b) = false .
  eq (a = intru) = false .
  eq (b = intru) = false .
  eq mlk-getSecret(asymMlkPkEph(ab)) = msk .
  eq asymSid(ab) = sid .
  eq validAsymBody(a,b,ab) = true .
  eq (msk \in leakscr(s)) = false .
  eq (msg(a2,a,b,ab,n) \in nw(s)) = true .
  eq asymMlkCt(ab) = mlk-encapsC(mpk,msk) .
  eq (mlk-getSecret(mpk) \in leakscr(s)) = false .
  eq (sk(a) \in leakscr(s)) = false .
  eq ((mlk-getSecret(mpk) & msk) \in knl(s)) = false .
  eq ((mlk-getSecret(mpk) & msk) \in leakscr(s)) = false .
  eq mlk-getSecret(mpk) = r1 .
  eq (r1 \in leakscr(s)) = false .
  eq ((r1 & msk) \in knl(s)) = false .
  eq ((r1 & msk) \in leakscr(s)) = false .
  eq mlk-getSecret(r2) = msk .
  eq mlk-decaps(r2,r1) = (r1 & msk) .
  red inv2(s,r1) implies (keyPairSeAsym(s,a2,a,b,sid,mpk,msk,ab,n) implies keyPairSeAsym(intruMLKDecaps(s,r1,r2),a2,a,b,sid,mpk,msk,ab,n)) .
close

